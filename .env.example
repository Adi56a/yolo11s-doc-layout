# ==============================================================================
# MARKSENSE PIPELINE CONFIGURATION TEMPLATE (.env.example)
# Rename this file to '.env' and fill in your actual settings.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. AWS S3 Storage Settings
# ------------------------------------------------------------------------------
# These credentials are used by s3_helper.py to upload page PNGs and cropped answer blocks.
# Required only if USE_LOCAL_STORAGE=False.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# The region where your S3 bucket resides (e.g. ap-south-1)
AWS_REGION=ap-south-1

# Target S3 bucket name
S3_BUCKET_NAME=edtech-b2b-media


# ------------------------------------------------------------------------------
# 2. Pipeline Offline / Storage Mock Mode
# ------------------------------------------------------------------------------
# Set to 'True' to run entirely locally without hitting the network or S3.
# Files will be written to the LOCAL_STORAGE_DIR path simulating S3 folders.
# Set to 'False' to enable real AWS S3 network uploads.
USE_LOCAL_STORAGE=True

# Directory to save mock S3 files locally (defaults to outputs/local_s3_mock)
LOCAL_STORAGE_DIR=outputs/local_s3_mock


# ------------------------------------------------------------------------------
# 3. OCR Engine Configuration
# ------------------------------------------------------------------------------
# Choose which OCR text extraction engine to use:
#   - 'mock': Offline fallback mode. Instantly generates realistic mock text matching 
#             block indices. Zero dependencies/installs required.
#   - 'easyocr': Uses local deep learning model. Good quality. Needs 'pip install easyocr'.
#   - 'pytesseract': Uses Tesseract CLI wrapper. Needs 'pip install pytesseract' AND 
#                    Tesseract binary installed on your system path.
OCR_ENGINE=mock


# ------------------------------------------------------------------------------
# 4. YOLO Layout Model Configuration
# ------------------------------------------------------------------------------
# Path to your custom trained YOLO weights (.onnx or .pt file formats are supported)
YOLO_WEIGHTS_PATH=models/best.onnx

# Minimum confidence score (0.05 to 1.0) required to process layout detections
YOLO_CONF_THRESHOLD=0.25
